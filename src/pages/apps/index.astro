---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Apps" description="Apps and tools from IoniaScience.">
  <section class="site-container pt-32 pb-20">
    <div class="max-w-3xl">
      <p class="mb-3 text-sm font-medium uppercase tracking-wide opacity-70">Apps</p>
      <h1 class="h1 mb-6">Apps and tools</h1>
      <p class="description max-w-2xl">
        This section will feature IoniaScience apps, experiments, and tools as they come online.
        For now, the blog is the main public output.
      </p>
    </div>
  </section>
</BaseLayout>
